# ===== Telegram =====
TELEGRAM_BOT_TOKEN=                # от @BotFather для @Academ4I_bot
TELEGRAM_WEBHOOK_SECRET=change-me  # любая длинная строка
WEBHOOK_DOMAIN=academ4i.duckdns.org

# ===== AI: ProxyAPI (один ключ на OpenAI + Anthropic) =====
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_USE_EXTENDED_THINKING=true

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
EMBEDDING_MODEL=text-embedding-3-small
PARSER_MODEL=gpt-4o

# ===== БД: Supabase Postgres (Transaction pooler) =====
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PWD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_KEY=
SUPABASE_PROJECT_REF=

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Тарифы =====
FREE_LIFETIME_TASKS=5
PREMIUM_PRICE_STARS=150
PREMIUM_DURATION_DAYS=30

# ===== Прочее =====
ENV=production
LOG_LEVEL=INFO
SENTRY_DSN=
